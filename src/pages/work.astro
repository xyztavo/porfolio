---
import ProjectCard from "../components/ProjectCard.astro";
import Button from "../components/ui/Button.astro";
import BottomNav from "../components/BottomNav.astro";
import { siteConfig } from "../config/site";
import "../styles/globals.css"
---

<html lang="en" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="/src/styles/globals.css" />
    <title>Work - Gustavo Luna</title>
  </head>
  <body class="bg-background text-foreground font-inter">
    <div id="app">
      <div class="container mx-auto px-4 py-16 max-w-7xl">
        <!-- Header -->
        <div class="text-center mb-16 animate-fade-in">
          <h1 class="text-5xl md:text-7xl font-bold mb-4 glow-text">
            {siteConfig.pages.work.title}
          </h1>
          <p class="text-xl text-zinc-400 mb-8">
            {siteConfig.pages.work.subtitle}
          </p>
          <a 
            href={siteConfig.contact.github}
            target="_blank" 
            class="inline-flex items-center gap-2 text-zinc-400 hover:text-white transition-colors"
          >
            View full GitHub profile →
          </a>
        </div>

        <!-- Projects Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
          {siteConfig.projects.map((project, index) => (
            <div 
              class="animate-project-card"
              style={`animation-delay: ${index * 0.1}s`}
            >
              <ProjectCard 
                name={project.title}
                description={project.description}
                technologies={project.tags}
                githubUrl={project.github}
                liveUrl={project.liveUrl}
                featured={project.featured}
                contributed={project.contributed}
              />
            </div>
          ))}
        </div>

        <!-- CTA to Experiences -->
        <div class="text-center animate-fade-in mt-20 mb-24">
          <p class="text-zinc-400 mb-6 text-lg">
            Want to know more about my journey?
          </p>
          <Button href={siteConfig.pages.work.ctaLink}>
            {siteConfig.pages.work.ctaText}
          </Button>
        </div>
      </div>
    </div>
    <BottomNav currentPage="work" />
  </body>
</html>

<style>
  .animate-project-card {
    opacity: 0;
    animation: fadeSlideUp 0.6s ease-out forwards;
  }

  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
