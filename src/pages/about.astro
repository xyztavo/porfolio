---
import BottomNav from "../components/BottomNav.astro";
import Button from "../components/ui/Button.astro";
import { MapPin, Mail, Phone, Linkedin } from '@lucide/astro';
import { siteConfig } from "../config/site";
import "../styles/globals.css"
---

<html lang="en" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>About - Gustavo Luna</title>
  </head>
  <body class="bg-background text-foreground font-inter">
    <div id="app">
      <div class="container mx-auto px-4 py-16 max-w-5xl">
        <!-- Header -->
        <div class="text-center mb-16 animate-fade-in">
          <h1 class="text-5xl md:text-7xl font-bold mb-4 glow-text">
            {siteConfig.pages.about.title}
          </h1>
          <p class="text-xl text-zinc-400">
            {siteConfig.pages.about.subtitle}
          </p>
        </div>

        <!-- Content Grid -->
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Profile Image -->
          <div class="md:col-span-1 animate-fade-in">
            <div class="aspect-square bg-zinc-900/50 border border-zinc-800 rounded-lg overflow-hidden hover:border-zinc-600 transition-all">
              <img 
                src={siteConfig.personal.profileImage}
                alt={`${siteConfig.personal.name} Profile`}
                class="w-full h-full object-cover"
              />
            </div>
          </div>

          <!-- Bio & Info -->
          <div class="md:col-span-2 space-y-6">
            <!-- Bio -->
            <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all animate-fade-in">
              <h2 class="text-2xl font-bold text-white mb-4">Hello!</h2>
              <div class="text-zinc-400 space-y-3 leading-relaxed">
                {siteConfig.personal.bio.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </div>

            <!-- Areas of Interest -->
            <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all animate-fade-in">
              <h3 class="text-xl font-bold text-white mb-4">Areas of Interest</h3>
              <div class="flex flex-wrap gap-2">
                {siteConfig.personal.areasOfInterest.map((area) => (
                  <span class="px-3 py-1.5 bg-zinc-800 text-zinc-300 rounded-full text-sm border border-zinc-700">
                    {area}
                  </span>
                ))}
              </div>
            </div>

            <!-- Contact Info -->
            <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all animate-fade-in">
              <h3 class="text-xl font-bold text-white mb-4">Contact Information</h3>
              <div class="space-y-3">
                <div class="flex items-center gap-3 text-zinc-400">
                  <MapPin size={18} class="text-zinc-500" />
                  <span>{siteConfig.contact.location}</span>
                </div>
                <div class="flex items-center gap-3 text-zinc-400">
                  <Phone size={18} class="text-zinc-500" />
                  <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors">
                    {siteConfig.contact.phone}
                  </a>
                </div>
                <div class="flex items-center gap-3 text-zinc-400">
                  <Mail size={18} class="text-zinc-500" />
                  <a href={`mailto:${siteConfig.contact.email}`} class="hover:text-white transition-colors">
                    {siteConfig.contact.email}
                  </a>
                </div>
                <div class="flex items-center gap-3 text-zinc-400">
                  <Linkedin size={18} class="text-zinc-500" />
                  <a 
                    href={siteConfig.contact.linkedin}
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="hover:text-white transition-colors"
                  >
                    {siteConfig.contact.linkedin.replace('https://', '')}
                  </a>
                </div>
              </div>
            </div>

            <!-- Languages -->
            <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all animate-fade-in">
              <h3 class="text-xl font-bold text-white mb-4">Languages</h3>
              <div class="space-y-2">
                {siteConfig.languages.map((lang) => (
                  <div class="flex justify-between items-center">
                    <span class="text-zinc-300">{lang.name}</span>
                    <span class="text-zinc-500 text-sm">{lang.level}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="mt-16 text-center animate-fade-in">
          <Button href={siteConfig.pages.about.ctaLink}>
            {siteConfig.pages.about.ctaText}
          </Button>
        </div>
      </div>
    </div>
    <BottomNav currentPage="about" />
  </body>
</html>
