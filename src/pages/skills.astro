---
import BottomNav from "../components/BottomNav.astro";
import Button from "../components/ui/Button.astro";
import "../styles/globals.css"
---

<html lang="en" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Skills - Gustavo Luna</title>
  </head>
  <body class="bg-background text-foreground font-inter">
    <div id="app">
      <div class="container mx-auto px-4 py-16 max-w-6xl">
        <!-- Header -->
        <div class="text-center mb-16 animate-fade-in">
          <h1 class="text-5xl md:text-7xl font-bold mb-4 glow-text">
            My Skills
          </h1>
          <p class="text-xl text-zinc-400">
            Technologies and tools I work with
          </p>
        </div>

        <!-- Skills Grid -->
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Backend -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">Backend</h2>
            <div class="space-y-6">
              <!-- Golang -->
              <div class="space-y-3">
                <h3 class="text-lg font-semibold text-zinc-300">Golang</h3>
                <div class="grid grid-cols-2 gap-3">
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/go/white" alt="Go" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">Chi</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/go/white" alt="Fiber" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">Fiber</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/uber/white" alt="UberFX" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">UberFX</span>
                  </div>
                </div>
              </div>

              <!-- Node.js -->
              <div class="space-y-3">
                <h3 class="text-lg font-semibold text-zinc-300">Node.js</h3>
                <div class="grid grid-cols-2 gap-3">
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/nodedotjs/white" alt="Node.js" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">Elysia</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/express/white" alt="Express" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">Express</span>
                  </div>
                  <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                    <img src="https://cdn.simpleicons.org/fastify/white" alt="Fastify" class="w-8 h-8 grayscale opacity-80" />
                    <span class="text-sm text-zinc-400">Fastify</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Frontend -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">Frontend</h2>
            <div class="space-y-3">
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/react/white" alt="React" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">React</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/nextdotjs/white" alt="Next.js" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Next.js</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/qwik/white" alt="Qwik" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Qwik</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/typescript/white" alt="TypeScript" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">TypeScript</span>
              </div>
            </div>
          </div>

          <!-- Databases -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">Databases</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/postgresql/white" alt="PostgreSQL" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">PostgreSQL</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/mongodb/white" alt="MongoDB" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">MongoDB</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/turso/white" alt="Turso" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Turso</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/pocketbase/white" alt="PocketBase" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">PocketBase</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/mysql/white" alt="MySQL" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">MySQL</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/amazons3/white" alt="S3" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Object Storage</span>
              </div>
            </div>
          </div>

          <!-- Tools & Others -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">Tools & Others</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/git/white" alt="Git" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Git</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/githubactions/white" alt="CI/CD" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">CI/CD</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/drizzle/white" alt="Drizzle ORM" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Drizzle ORM</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/nestjs/white" alt="NestJS" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">NestJS</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/googlesearchconsole/white" alt="SEO" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">SEO</span>
              </div>
            </div>
          </div>

          <!-- Infrastructure & Hosting -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">Infrastructure & Hosting</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/debian/white" alt="Debian" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Debian VPS</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/docker/white" alt="Docker" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Docker</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/systemd/white" alt="Systemd" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Systemd</span>
              </div>
              <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                <img src="https://cdn.simpleicons.org/caddy/white" alt="Caddy" class="w-8 h-8 grayscale opacity-80" />
                <span class="text-sm text-zinc-400">Caddy</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Additional Note -->
        <div class="mt-12 text-center text-zinc-500 text-sm animate-fade-in">
          <p>Always learning and exploring new technologies</p>
        </div>

        <!-- CTA Button -->
        <div class="mt-12 text-center animate-fade-in">
          <Button href="https://github.com/xyztavo">
            View My GitHub
          </Button>
        </div>
      </div>
    </div>
    <BottomNav currentPage="skills" />
  </body>
</html>
