---
import BottomNav from "../components/BottomNav.astro";
import Button from "../components/ui/Button.astro";
import { siteConfig } from "../config/site";
import "../styles/globals.css"
---

<html lang="en" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Skills - Gustavo Luna</title>
  </head>
  <body class="bg-background text-foreground font-inter">
    <div id="app">
      <div class="container mx-auto px-4 py-16 max-w-6xl">
        <!-- Header -->
        <div class="text-center mb-16 animate-fade-in">
          <h1 class="text-5xl md:text-7xl font-bold mb-4 glow-text">
            {siteConfig.pages.skills.title}
          </h1>
          <p class="text-xl text-zinc-400">
            {siteConfig.pages.skills.subtitle}
          </p>
        </div>

        <!-- Skills Grid -->
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Backend -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">{siteConfig.skills.backend.title}</h2>
            <div class="space-y-6">
              {siteConfig.skills.backend.items.map((item: any) => (
                <div class="space-y-3">
                  <h3 class="text-lg font-semibold text-zinc-300">{item.category}</h3>
                  <div class="grid grid-cols-2 gap-3">
                    {item.technologies.map((tech: any) => (
                      <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                        <img src={tech.icon} alt={tech.name} class="w-8 h-8 grayscale opacity-80" />
                        <span class="text-sm text-zinc-400">{tech.name}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Frontend -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">{siteConfig.skills.frontend.title}</h2>
            <div class="space-y-3">
              {siteConfig.skills.frontend.items.map((item: any) => (
                <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                  <img src={item.icon} alt={item.name} class="w-8 h-8 grayscale opacity-80" />
                  <span class="text-sm text-zinc-400">{item.name}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Databases -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">{siteConfig.skills.databases.title}</h2>
            <div class="grid grid-cols-2 gap-3">
              {siteConfig.skills.databases.items.map((item: any) => (
                <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                  <img src={item.icon} alt={item.name} class="w-8 h-8 grayscale opacity-80" />
                  <span class="text-sm text-zinc-400">{item.name}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Tools & Others -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">{siteConfig.skills.tools.title}</h2>
            <div class="grid grid-cols-2 gap-3">
              {siteConfig.skills.tools.items.map((item: any) => (
                <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                  <img src={item.icon} alt={item.name} class="w-8 h-8 grayscale opacity-80" />
                  <span class="text-sm text-zinc-400">{item.name}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Infrastructure & Hosting -->
          <div class="bg-zinc-900/50 border border-zinc-800 rounded-lg p-8 hover:border-zinc-600 transition-all animate-fade-in">
            <h2 class="text-2xl font-bold text-white mb-6">{siteConfig.skills.infrastructure.title}</h2>
            <div class="grid grid-cols-2 gap-3">
              {siteConfig.skills.infrastructure.items.map((item: any) => (
                <div class="flex items-center gap-3 p-3 bg-zinc-800/50 rounded-lg border border-zinc-700">
                  <img src={item.icon} alt={item.name} class="w-8 h-8 grayscale opacity-80" />
                  <span class="text-sm text-zinc-400">{item.name}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Additional Note -->
        <div class="mt-12 text-center text-zinc-500 text-sm animate-fade-in">
          <p>{siteConfig.pages.skills.footer}</p>
        </div>

        <!-- CTA Button -->
        <div class="mt-12 text-center animate-fade-in">
          <Button href={siteConfig.contact.github}>
            {siteConfig.pages.skills.ctaText}
          </Button>
        </div>
      </div>
    </div>
    <BottomNav currentPage="skills" />
  </body>
</html>
